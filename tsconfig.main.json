{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "outDir": "dist/main",
    "rootDir": "src/main"
  },
  "include": ["src/main/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
