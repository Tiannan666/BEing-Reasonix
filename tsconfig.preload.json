{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "outDir": "dist/preload",
    "rootDir": "src/preload"
  },
  "include": ["src/preload/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
